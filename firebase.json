{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "emailPassword": true
    }
  },
  "hosting": [
    {
      "target": "admin",
      "public": "admin/build/web",
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "client",
      "public": "client/build/web",
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "hosting": { "port": 5000 }
  }
}
